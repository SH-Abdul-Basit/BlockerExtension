{
  "manifest_version": 3,
  "name": "ClearTab",
  "version": "0.1",

  "browser_specific_settings": {
  "gecko": {
    "id": "ClearTab@gmail.com",
    "data_collection_permissions": {
          "required": [
             "locationInfo"
          ]
    }
   }
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "description": "Adds to block sites according to your needs.",
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    },
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["content/disableBGM.js"]
    }
  ],

  "options_ui": {
  "page": "settings/settings.html",
  "open_in_tab": true 
  },
  
  "background": {
    "scripts": [
      "background/background.js",
      "background/disableBGM.js"
    ]
  },

 "icons": {
    "48": "icons/icon.png"
  },


  "permissions": [
    "tabs",
    "storage"
  ]
}       
